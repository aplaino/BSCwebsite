DJANGO_SECRET_KEY=replace-with-a-secure-random-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=
DJANGO_STATIC_ROOT=
DJANGO_MEDIA_ROOT=
DJANGO_SERVE_MEDIA_FILES=True
DJANGO_FRONTEND_SITE_URL=http://localhost:5173

DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=your-restaurant-email@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-app-specific-password
DJANGO_DEFAULT_FROM_EMAIL=Buster's Sea Cove <your-restaurant-email@gmail.com>
